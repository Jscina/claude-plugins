#!/usr/bin/env python3
"""
rag-migrate — bring an existing rag-memory/ corpus up to the current plugin format generation.

Idempotent and dry-run by default. Safe to re-run.

Files self-describe via a `format_gen` integer in their frontmatter header (legacy name `plugin_schema`
is swept to `format_gen` on migration). Each KIND of file is brought only up to its own kind's latest
format generation (system docs and issue cards version independently), so a release that changes one
kind never rewrites the other.

What it does (only what's needed):
  * creates missing lifecycle dirs (issues/backlog, issues/done; plus any missing
    issues/archive or system/* leaves)
  * writes rag-memory/.gitignore (the commit boundary) if absent
  * untracks git-tracked local-state files -- everything under issues/active|backlog|done
    and every trace.md (incl. archive/closed) -- via `git rm --cached` (--apply only,
    files are kept on disk)
  * refreshes generated docs (README.md, issues/README.md, BENCHMARKS.md, system/README.md)
    ONLY when they still match a known old template (never clobbers your edits)
  * DOC PASS — brings system/ knowledge docs to the doc format generation. A doc with no frontmatter
    is bootstrapped (title/domain/source_cards/created/updated derived from the **Source** labels and
    H1 already in it); one that has a header gets its format_gen swept/stamped. Body never touched.
    Scans every subfolder of system/ (nesting allowed); README.md and root-level *.md are excluded.
  * CARD PASS — brings each issue card's context.md (in backlog/active/done/archive) to the card format
    generation, whenever behind. A card with no header is bootstrapped from its Issue Summary fields;
    trace.md/benchmarks.md are left alone (their entry blocks would collide with a header). Body never
    touched.
  * stamps .rag-meta.json with the current corpus format_gen (high-water across kinds)

Usage:
  rag-migrate [--root PATH]            # dry-run: print the plan
  rag-migrate --check                  # exit 10 if migration needed, 0 if up-to-date
  rag-migrate --apply                  # perform the migration

Dependencies: Python 3 standard library + git on PATH (used only for untracking).
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import subprocess
import sys
from pathlib import Path

META_FILE = ".rag-meta.json"
GITIGNORE_TEMPLATE = "corpus-gitignore"

# The format generation at which each KIND of file's on-disk format last changed. The migrator brings
# a file only up to its own kind's generation, so a release that changes one kind never rewrites the
# other. Kind is obvious from location: system/ = doc, issues/.../context.md = card.
LATEST_GEN = {"doc": 3, "card": 4}
CORPUS_GEN = max(LATEST_GEN.values())  # high-water mark stamped into .rag-meta.json (format_gen)

REQUIRED_DIRS = (
    "issues/backlog", "issues/active", "issues/done", "issues/archive",
    "system/architecture", "system/schemas", "system/services", "system/known-behaviors",
)
# Committed dirs want a .gitkeep when freshly created empty (gitignored dirs don't).
COMMITTED_EMPTY_DIRS = {
    "issues/archive",
    "system/architecture", "system/schemas", "system/services", "system/known-behaviors",
}

# Generated docs that changed in this schema: corpus path -> (template, {known-old sha256}).
DOC_MAP = {
    "README.md": ("root-readme.md", {"74f60c46425156057cf77d7bfdf4785d1afef676cd6acf42ab44bcafa0808840"}),
    "issues/README.md": ("issues-readme.md", {"adda8effc7ed2457e750055cf5f8de4ae8322778865646aca2fdbc3b9c29ec7e"}),
    "BENCHMARKS.md": ("benchmarks.md", {"429bf262350255e0429a90e3bfc66b9b92a9549150e53785be86a7a5b0b036bc"}),
    "system/README.md": ("system-readme.md",
                          {"cf7e3f663c02b4a7aac6db33f9b2e4c9e9f65490a6e44d5534dcf8dcc3c3b9de",   # v0.3.0
                           "c824fd9e4a88f0c93a90e1e971379baadddbe634f0826c1eae440802491e5328"}),  # v0.4.0
}

# system/ knowledge docs carry a YAML frontmatter header. They live in ANY subfolder of system/
# (nested allowed); the `domain` is the doc's path relative to system/. READMEs anywhere and any
# *.md directly under system/ (no domain subfolder) are excluded.
# Matches a per-section provenance label: **Source**: CARD-XXXX | YYYY-MM-DD
SOURCE_RE = re.compile(r"^\*\*Source\*\*:\s*(CARD-[A-Za-z0-9._-]+)\s*\|\s*(\d{4}-\d{2}-\d{2})", re.M)
H1_RE = re.compile(r"^#\s+(.+?)\s*$", re.M)

# The per-file format-generation stamp: `format_gen: N`, or the legacy `plugin_schema: N` (swept to
# format_gen on migration). FORMAT_GEN_RE captures the integer value of either key.
FORMAT_GEN_KEYS = ("format_gen", "plugin_schema")
FORMAT_GEN_RE = re.compile(r"^(?:format_gen|plugin_schema):\s*(\d+)\s*$")

# Issue cards: the card pass walks context.md in each lifecycle dir. The header is bootstrapped from the
# "## Issue Summary" bold-label fields the card templates already write.
CARD_DIRS = ("backlog", "active", "done", "archive")
# The Issue Summary fields are markdown list items ("- **Card ID**: ..."), so allow an optional
# leading list marker before the bold label.
CARD_ID_RE = re.compile(r"^\s*[-*]?\s*\*\*Card ID\*\*:\s*(.+?)\s*$", re.M)
CARD_SOURCE_RE = re.compile(r"^\s*[-*]?\s*\*\*Source\*\*:\s*(.+?)\s*$", re.M)
CARD_OPENED_RE = re.compile(r"^\s*[-*]?\s*\*\*Date Opened\*\*:\s*(.+?)\s*$", re.M)


def sha256(text: str) -> str:
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def find_templates_dir(override: str | None) -> Path:
    candidates: list[Path] = []
    if override:
        candidates.append(Path(override).expanduser())
    pr = os.environ.get("CLAUDE_PLUGIN_ROOT")
    if pr:
        candidates.append(Path(pr) / "skills" / "init" / "templates")
    candidates.append(Path(__file__).resolve().parents[1] / "skills" / "init" / "templates")
    for c in candidates:
        if (c / GITIGNORE_TEMPLATE).is_file():
            return c
    raise FileNotFoundError("could not locate init templates; pass --templates-dir")


def find_corpus_root(override: str | None) -> Path:
    if override:
        root = Path(override).expanduser().resolve()
        if not (root / "issues").is_dir():
            raise FileNotFoundError(f"--root {root} has no issues/ dir; is it a rag-memory corpus?")
        return root
    cwd = Path.cwd().resolve()
    if (cwd / "rag-memory" / "issues").is_dir():
        return cwd / "rag-memory"
    for p in (cwd, *cwd.parents):
        if p.name == "rag-memory" and (p / "issues").is_dir():
            return p
        if (p / "rag-memory" / "issues").is_dir():
            return p / "rag-memory"
    raise FileNotFoundError(f"no rag-memory/ corpus found from {cwd}; pass --root")


def read_corpus_gen(root: Path) -> int:
    meta = root / META_FILE
    if not meta.is_file():
        return 0
    try:
        data = json.loads(meta.read_text(encoding="utf-8"))
        # current key: format_gen; legacy keys: plugin_schema (0.4.0), schema (<= 0.3.0).
        return int(data.get("format_gen", data.get("plugin_schema", data.get("schema", 0))))
    except (ValueError, OSError):
        return 0


def git_tracked_local_state(root: Path) -> list[str]:
    """Tracked files (relative to root) that must be local-only under the new boundary."""
    try:
        out = subprocess.run(
            ["git", "-C", str(root), "ls-files"],
            capture_output=True, text=True, check=True,
        ).stdout
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []  # not a git repo, or git missing -> nothing to untrack
    bad = set()
    for line in out.splitlines():
        f = line.strip()
        if not f:
            continue
        if f.startswith(("issues/active/", "issues/backlog/", "issues/done/")):
            bad.add(f)
        elif f == "trace.md" or f.endswith("/trace.md"):
            bad.add(f)
    return sorted(bad)


def iter_system_docs(base: Path):
    """Yield system/ knowledge docs: any *.md under a subfolder of system/ (nesting allowed).

    Skips README.md anywhere and any *.md directly under system/ (those have no domain subfolder)."""
    if not base.is_dir():
        return
    for f in sorted(base.rglob("*.md")):
        if f.name.lower() == "readme.md":
            continue
        if f.parent == base:
            continue
        yield f


def _yaml_dq(s: str) -> str:
    """Double-quote a scalar so colons/brackets/backticks in titles stay valid YAML."""
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def _build_doc_header(path: Path, base: Path, target: int) -> str:
    """Bootstrap a full frontmatter header for a system/ doc that has none, derived from its body.

    Hybrid model — the per-section **Source** lines stay for finding-level attribution; the header
    aggregates them at the file level. The body is never modified."""
    text = path.read_text(encoding="utf-8")
    m = H1_RE.search(text)
    title = m.group(1).strip() if m else path.stem.replace("-", " ").title()

    cards: list[str] = []
    dates: list[str] = []
    for card, date in SOURCE_RE.findall(text):
        if card not in cards:
            cards.append(card)
        dates.append(date)

    lines = [
        "---",
        f"title: {_yaml_dq(title)}",
        f"domain: {path.parent.relative_to(base).as_posix()}",
        "source_cards: [" + ", ".join(cards) + "]",
    ]
    if dates:
        lines.append(f"created: {min(dates)}")
        lines.append(f"updated: {max(dates)}")
    lines.append("status: active")
    lines.append(f"format_gen: {target}")
    lines.append("tags: []")
    lines.append("---")
    return "\n".join(lines) + "\n\n" + text


def _build_card_header(ctx: Path, target: int) -> str:
    """Bootstrap a frontmatter header for an issue card's context.md, from its Issue Summary fields.

    Lifecycle state (backlog/active/done/archive) is intentionally NOT stored here — the directory is
    the single source of truth for it. The body is never modified."""
    text = ctx.read_text(encoding="utf-8")
    m_id = CARD_ID_RE.search(text)
    card_id = m_id.group(1).strip() if m_id else ctx.parent.name
    m_src = CARD_SOURCE_RE.search(text)
    source = m_src.group(1).strip() if m_src else ""
    m_op = CARD_OPENED_RE.search(text)
    opened = m_op.group(1).strip() if m_op else ""
    m_h1 = H1_RE.search(text)
    h1 = m_h1.group(1).strip() if m_h1 else ""
    title = h1 if (h1 and h1 != card_id) else ""  # H1 is usually just the id -> leave title blank

    lines = [
        "---",
        f"card_id: {card_id}",
        f"title: {_yaml_dq(title)}",
        f"source: {_yaml_dq(source)}" if source else "source:",
        f"opened: {opened}" if opened else "opened:",
        "closed:",
        f"format_gen: {target}",
        "tags: []",
        "---",
    ]
    return "\n".join(lines) + "\n\n" + text


def _ensure_format_gen(text: str, target: int) -> str | None:
    """A file with a frontmatter header: ensure a `format_gen` field is present and >= target.

    Also performs the one-time field SWEEP: a legacy `plugin_schema:` line is renamed to `format_gen:`
    (value preserved). The field is detected by key (any value), so a non-integer value can never
    produce a duplicate key. Returns updated text, or None if already current (idempotent). Only the
    one header line is touched; every other field and the entire body are left exactly as-is."""
    lines = text.split("\n")
    if not lines or lines[0].strip() != "---":
        return None
    close = next((i for i in range(1, len(lines)) if lines[i].strip() == "---"), None)
    if close is None:
        return None  # malformed header; leave it alone

    header = lines[1:close]
    idx = key = cur = None
    for j, ln in enumerate(header):
        s = ln.strip()
        for k in FORMAT_GEN_KEYS:
            if s.startswith(k + ":"):
                idx, key = j, k
                mm = FORMAT_GEN_RE.match(s)
                cur = int(mm.group(1)) if mm else None  # unparseable -> needs replacement
                break
        if idx is not None:
            break

    if idx is not None:
        # Up to date only if already canonically named AND at/after target (else rekey/bump).
        if key == "format_gen" and cur is not None and cur >= target:
            return None
        new_val = target if cur is None else max(cur, target)
        header[idx] = f"format_gen: {new_val}"
    else:
        # Insert just after `status:`, else just before `tags:`, else at the end of the header.
        status_idx = tags_idx = None
        for j, ln in enumerate(header):
            s = ln.strip()
            if s.startswith("status:") and status_idx is None:
                status_idx = j
            elif s.startswith("tags:") and tags_idx is None:
                tags_idx = j
        insert_at = (status_idx + 1) if status_idx is not None else (
            tags_idx if tags_idx is not None else len(header))
        header.insert(insert_at, f"format_gen: {target}")
    return "\n".join(["---", *header, "---", *lines[close + 1:]])


def migrate_doc(path: Path, base: Path, target: int):
    """Bring one system/ doc to the doc format generation. Returns (label, new_text) or None.

    - No frontmatter  -> bootstrap a full header (derived from the body), stamped format_gen.
    - Has frontmatter -> ensure/sweep format_gen (rename legacy plugin_schema, bump only if behind).
    Forward-only and idempotent: a doc already current yields None."""
    text = path.read_text(encoding="utf-8")
    if text.startswith("---\n") or text.startswith("---\r"):
        updated = _ensure_format_gen(text, target)
        return None if updated is None else ("update header on", updated)
    return ("add frontmatter to", _build_doc_header(path, base, target))


def iter_cards(root: Path):
    """Yield each issue card's context.md across all lifecycle dirs (backlog/active/done/archive)."""
    issues = root / "issues"
    for sub in CARD_DIRS:
        d = issues / sub
        if not d.is_dir():
            continue
        for card in sorted(d.iterdir()):
            ctx = card / "context.md"
            if card.is_dir() and ctx.is_file():
                yield ctx


def migrate_card(ctx: Path, target: int):
    """Bring one issue card's context.md to the card format generation. Returns (label, new_text) or None.

    - No frontmatter  -> bootstrap a header from the Issue Summary fields, stamped format_gen.
    - Has frontmatter -> ensure/sweep format_gen. The body (Issue Summary etc.) is never modified."""
    text = ctx.read_text(encoding="utf-8")
    if text.startswith("---\n") or text.startswith("---\r"):
        updated = _ensure_format_gen(text, target)
        return None if updated is None else ("update card header on", updated)
    return ("add card header to", _build_card_header(ctx, target))


def build_plan(root: Path, templates: Path, corpus_gen: int, meta_text: str):
    """Return list of (category, message, action|None). None action == advisory warning."""
    actions = []

    for d in REQUIRED_DIRS:
        if not (root / d).is_dir():
            actions.append(("mkdir", f"create {d}/", ("mkdir", root / d, d in COMMITTED_EMPTY_DIRS)))

    gi = root / ".gitignore"
    if not gi.is_file():
        actions.append(("gitignore", "write .gitignore (commit boundary)",
                        ("write", gi, (templates / GITIGNORE_TEMPLATE).read_text(encoding="utf-8"))))
    elif "**/trace.md" not in gi.read_text(encoding="utf-8"):
        actions.append(("gitignore",
                        "WARN: existing .gitignore lacks '**/trace.md' — add the boundary rules by hand", None))

    tracked = git_tracked_local_state(root)
    if tracked:
        actions.append(("untrack",
                        f"git rm --cached {len(tracked)} tracked local-state file(s) (kept on disk)",
                        ("untrack", root, tracked)))

    for rel, (tmpl_name, old_hashes) in DOC_MAP.items():
        doc = root / rel
        new_text = (templates / tmpl_name).read_text(encoding="utf-8")
        if not doc.is_file():
            actions.append(("doc", f"write missing {rel}", ("write", doc, new_text)))
            continue
        h = sha256(doc.read_text(encoding="utf-8"))
        if h == sha256(new_text):
            continue  # already current
        if h in old_hashes:
            actions.append(("doc", f"refresh {rel} (matches old template)", ("write", doc, new_text)))
        else:
            actions.append(("doc", f"WARN: {rel} was modified — left as-is (update by hand if needed)", None))

    # Doc pass: system/ knowledge docs, brought only up to the doc generation (no churn on a
    # card-only release). Also sweeps the legacy plugin_schema field to format_gen.
    base = root / "system"
    for doc in iter_system_docs(base):
        res = migrate_doc(doc, base, LATEST_GEN["doc"])
        if res is not None:
            label, new_text = res
            rel = doc.relative_to(root).as_posix()
            actions.append(("doc-header", f"{label} {rel}", ("write", doc, new_text)))

    # Card pass: each card's context.md, brought up to the card generation, whenever behind.
    for ctx in iter_cards(root):
        res = migrate_card(ctx, LATEST_GEN["card"])
        if res is not None:
            label, new_text = res
            rel = ctx.relative_to(root).as_posix()
            actions.append(("card-header", f"{label} {rel}", ("write", ctx, new_text)))

    if read_corpus_gen(root) < corpus_gen:
        actions.append(("meta", f"stamp {META_FILE} (format_gen {corpus_gen})",
                        ("write", root / META_FILE, meta_text)))

    return actions


def apply_action(act) -> None:
    kind = act[0]
    if kind == "mkdir":
        _, p, want_keep = act
        p.mkdir(parents=True, exist_ok=True)
        if want_keep:
            (p / ".gitkeep").write_text("", encoding="utf-8")
    elif kind == "write":
        _, p, text = act
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(text, encoding="utf-8")
    elif kind == "untrack":
        _, root, files = act
        for i in range(0, len(files), 200):
            subprocess.run(["git", "-C", str(root), "rm", "--cached", "--quiet", "--", *files[i:i + 200]],
                           check=True)


def main(argv=None) -> int:
    ap = argparse.ArgumentParser(prog="rag-migrate",
                                 description="Upgrade a rag-memory corpus to the current format generation.")
    ap.add_argument("--root", default=None, help="Path to the rag-memory corpus (default: auto-detect)")
    ap.add_argument("--templates-dir", default=None, help="Override init templates directory")
    ap.add_argument("--check", action="store_true", help="exit 10 if migration is needed, 0 if up-to-date")
    ap.add_argument("--apply", action="store_true", help="perform the migration (default: dry-run)")
    args = ap.parse_args(argv)

    try:
        root = find_corpus_root(args.root)
        templates = find_templates_dir(args.templates_dir)
    except FileNotFoundError as e:
        print(f"rag-migrate: error: {e}", file=sys.stderr)
        return 2

    # The corpus generation is the script's high-water constant; the serialized .rag-meta.json content
    # comes from the shipped template (canonical form).
    corpus_gen = CORPUS_GEN
    meta_text = json.dumps({"format_gen": corpus_gen, "plugin": "rag"}, indent=2) + "\n"
    meta_tmpl = templates / "rag-meta.json"
    if meta_tmpl.is_file():
        meta_text = meta_tmpl.read_text(encoding="utf-8")

    actions = build_plan(root, templates, corpus_gen, meta_text)
    current = read_corpus_gen(root)

    if args.check:
        need = bool([a for a in actions if a[2] is not None]) or current < corpus_gen
        print(f"rag-migrate: {'migration needed' if need else 'up to date'} "
              f"(corpus {root}, format_gen {current} -> {corpus_gen})")
        return 10 if need else 0

    if not actions:
        print(f"rag-migrate: corpus is up to date (format_gen {corpus_gen}): {root}")
        return 0

    mode = "APPLY" if args.apply else "DRY-RUN"
    print(f"rag-migrate [{mode}] — corpus: {root} (format_gen {current} -> {corpus_gen})\n")
    warnings = []
    for cat, msg, act in actions:
        if act is None:
            print(f"  [WARN]  {msg}")
            warnings.append(msg)
            continue
        print(f"  [{'apply' if args.apply else 'plan '}] {msg}")
        if args.apply:
            apply_action(act)

    print()
    if not args.apply:
        print("Dry-run only. Re-run with --apply to perform these changes.")
        return 0

    print("Migration applied. Review and commit the boundary changes:")
    print(f"  cd {root}")
    print("  git status            # untracked traces are now staged deletions; new files are untracked")
    print("  git add -A && git commit -m 'chore(rag): migrate corpus to format_gen "
          f"{corpus_gen}'")
    if warnings:
        print("\nManual follow-ups:")
        for w in warnings:
            print(f"  - {w}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
