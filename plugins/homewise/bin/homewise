#!/usr/bin/env python3
"""
homewise - helper for the homewise plugin's evaluate / compare skills.

Part of the `homewise` plugin. `bin/` is on PATH when the plugin loads, so this is callable
as `homewise` from a skill or a shell.

Deterministic glue ONLY. It does not make buyer-judgment calls - which document is the MLS
vs. the disclosure, what counts as a priority item, the narrative wording. Those are the
model's job (see references/evaluation-rubric.md). This script just moves bytes around:

  homewise inventory <path...>    Recurse the given file(s)/dir(s) for PDFs and emit JSON
                                  (path, parent, size, pages, a text snippet) so the caller
                                  can classify each doc and group it by home WITHOUT relying
                                  on any fixed folder layout or filename convention.
  homewise extract <pdf>          Full text of a text-based PDF via `pdftotext -layout`.
                                  Use for MLS listings; a scanned Seller's Disclosure will
                                  come back empty - read those pages directly (vision).
  homewise html2pdf <html> [out]  Render an HTML doc to a print-optimized PDF. Tries, in
                                  order: $HOMEWISE_HTML2PDF, a local Chrome/Chromium, then
                                  wkhtmltopdf, then `npx puppeteer-cli`.

Dependencies: Python 3 stdlib. External tools (pdftotext, a browser, npx) are used when
present and reported clearly when not - the script never hard-fails the whole run for a
missing optional tool.
"""
from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

SNIPPET_CHARS = 1500
PDF_SUFFIXES = {".pdf"}

# Render script used by the node+puppeteer html2pdf fallback. Written into the puppeteer
# cache dir and run there, so `require('puppeteer')` resolves from the sibling node_modules.
RENDER_CJS = r"""
const puppeteer = require('puppeteer');
(async () => {
  const [, , input, output] = process.argv;
  const browser = await puppeteer.launch({
    headless: 'new',
    args: ['--no-sandbox', '--disable-setuid-sandbox', '--disable-gpu'],
  });
  const page = await browser.newPage();
  await page.goto('file://' + input, { waitUntil: 'networkidle0' });
  await page.pdf({ path: output, format: 'Letter', printBackground: true, preferCSSPageSize: true });
  await browser.close();
})().catch((e) => { console.error(String((e && e.stack) || e)); process.exit(1); });
"""


def _run(cmd: list[str]) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, capture_output=True, text=True)


def _have(tool: str) -> bool:
    return shutil.which(tool) is not None


# ---- PDF reading ----------------------------------------------------------

def pdf_pages(pdf: Path) -> int | None:
    if not _have("pdfinfo"):
        return None
    r = _run(["pdfinfo", str(pdf)])
    if r.returncode != 0:
        return None
    for line in r.stdout.splitlines():
        if line.lower().startswith("pages:"):
            try:
                return int(line.split(":", 1)[1].strip())
            except ValueError:
                return None
    return None


def pdf_text(pdf: Path, first: int | None = None, last: int | None = None,
             layout: bool = False) -> str:
    if not _have("pdftotext"):
        return ""
    cmd = ["pdftotext"]
    if layout:
        cmd.append("-layout")
    if first is not None:
        cmd += ["-f", str(first)]
    if last is not None:
        cmd += ["-l", str(last)]
    cmd += [str(pdf), "-"]
    r = _run(cmd)
    return r.stdout if r.returncode == 0 else ""


def snippet(pdf: Path) -> str:
    """First two pages, whitespace-collapsed and capped - enough to spot the address and
    the document type (MLS sheet vs. State Form 46234 disclosure vs. utility log)."""
    return " ".join(pdf_text(pdf, first=1, last=2).split())[:SNIPPET_CHARS]


def iter_pdfs(paths: list[str]):
    seen: set[Path] = set()
    for raw in paths:
        p = Path(raw).expanduser()
        candidates: list[Path] = []
        if p.is_dir():
            candidates = [f for f in sorted(p.rglob("*"))
                          if f.is_file() and f.suffix.lower() in PDF_SUFFIXES]
        elif p.is_file() and p.suffix.lower() in PDF_SUFFIXES:
            candidates = [p]
        # non-pdf / missing paths are skipped silently; inventory is best-effort
        for f in candidates:
            rp = f.resolve()
            if rp not in seen:
                seen.add(rp)
                yield rp


# ---- subcommands ----------------------------------------------------------

def cmd_inventory(args) -> int:
    items = []
    for pdf in iter_pdfs(args.path):
        try:
            size = pdf.stat().st_size
        except OSError:
            size = None
        items.append({
            "path": str(pdf),
            "name": pdf.name,
            "parent": pdf.parent.name,
            "size_bytes": size,
            "pages": pdf_pages(pdf),
            "snippet": snippet(pdf),
        })
    json.dump({"count": len(items), "pdftotext": _have("pdftotext"), "documents": items},
              sys.stdout, indent=2, ensure_ascii=False)
    sys.stdout.write("\n")
    if not items:
        print("homewise: no PDFs found under: " + ", ".join(args.path), file=sys.stderr)
    elif not _have("pdftotext"):
        print("homewise: note: pdftotext not found - snippets are empty; read the PDFs "
              "directly (vision) to classify them.", file=sys.stderr)
    return 0


def cmd_extract(args) -> int:
    pdf = Path(args.pdf).expanduser()
    if not pdf.is_file():
        print(f"homewise: error: not a file: {pdf}", file=sys.stderr)
        return 2
    if not _have("pdftotext"):
        print("homewise: error: pdftotext not found (install poppler). For scanned PDFs, "
              "read the pages directly with the Read tool instead.", file=sys.stderr)
        return 3
    first = last = None
    if args.pages:
        rng = args.pages.split("-", 1)
        try:
            first = int(rng[0])
            last = int(rng[1]) if len(rng) > 1 else first
        except ValueError:
            print(f"homewise: error: bad --pages {args.pages!r} (use N or N-M)", file=sys.stderr)
            return 2
    text = pdf_text(pdf, first=first, last=last, layout=not args.no_layout)
    sys.stdout.write(text)
    if not text.strip():
        print("homewise: note: no extractable text (likely a scanned/image PDF) - read it "
              "with the Read tool (vision) instead.", file=sys.stderr)
    return 0


def _chrome_binary() -> str | None:
    for name in ("google-chrome", "google-chrome-stable", "chromium", "chromium-browser",
                 "chrome", "brave-browser", "microsoft-edge"):
        if _have(name):
            return name
    return None


def _pdf_result(code: int, out: Path, via: str) -> int:
    if code == 0 and out.is_file():
        print(f"homewise: wrote {out} (via {via})")
        return 0
    print(f"homewise: error: PDF generation failed (via {via})", file=sys.stderr)
    return 1


def cmd_html2pdf(args) -> int:
    src = Path(args.html).expanduser().resolve()
    if not src.is_file():
        print(f"homewise: error: not a file: {src}", file=sys.stderr)
        return 2
    out = Path(args.out).expanduser().resolve() if args.out else src.with_suffix(".pdf")
    out.parent.mkdir(parents=True, exist_ok=True)

    # 1) explicit override - run as: <cmd> <in> <out> (through a shell, so a pipeline works)
    override = os.environ.get("HOMEWISE_HTML2PDF")
    if override:
        r = subprocess.run(f'{override} "{src}" "{out}"', shell=True)
        return _pdf_result(r.returncode, out, "$HOMEWISE_HTML2PDF")

    # 2) local Chrome/Chromium headless - honors @media print + @page in the doc's own CSS
    chrome = _chrome_binary()
    if chrome:
        r = _run([chrome, "--headless=new", "--no-sandbox", "--disable-gpu",
                  f"--print-to-pdf={out}", "--no-pdf-header-footer", src.as_uri()])
        if r.returncode == 0 and out.is_file():
            return _pdf_result(0, out, chrome)
        # else fall through

    # 3) wkhtmltopdf
    if _have("wkhtmltopdf"):
        r = _run(["wkhtmltopdf", "--print-media-type", "--enable-local-file-access",
                  str(src), str(out)])
        if r.returncode == 0 and out.is_file():
            return _pdf_result(0, out, "wkhtmltopdf")

    # 4) node + puppeteer, installed once into a cache dir (downloads Chromium on first run -
    #    the slow path). Modern puppeteer, launched with --no-sandbox so headless Chromium runs
    #    in restricted environments.
    if _have("npm") and _have("node"):
        cache = Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache"))) / "homewise"
        cache.mkdir(parents=True, exist_ok=True)
        puppeteer_pkg = cache / "node_modules" / "puppeteer"
        if not puppeteer_pkg.exists():
            print("homewise: installing puppeteer for PDF rendering (one-time, downloads Chromium - slow)...",
                  file=sys.stderr)
            subprocess.run(["npm", "install", "puppeteer@latest", "--prefix", str(cache),
                            "--no-fund", "--no-audit", "--loglevel", "error"])
        if puppeteer_pkg.exists():
            script = cache / "render-pdf.cjs"
            script.write_text(RENDER_CJS, encoding="utf-8")
            r = subprocess.run(["node", str(script), str(src), str(out)])
            if r.returncode == 0 and out.is_file():
                return _pdf_result(0, out, "node+puppeteer")

    print("homewise: error: no HTML->PDF path available. Install a browser (chromium/chrome) "
          "or wkhtmltopdf, ensure `npx` is on PATH, or set $HOMEWISE_HTML2PDF to a converter "
          "command. The HTML is complete and print-ready - you can also open it and use "
          "Print > Save as PDF.", file=sys.stderr)
    return 1


def main(argv=None) -> int:
    p = argparse.ArgumentParser(prog="homewise", description="Helper for the homewise plugin.")
    sub = p.add_subparsers(dest="cmd", required=True)

    pi = sub.add_parser("inventory", help="Recurse path(s) for PDFs; emit JSON with text snippets.")
    pi.add_argument("path", nargs="+", help="Files or directories to scan (recursive).")
    pi.set_defaults(func=cmd_inventory)

    pe = sub.add_parser("extract", help="Extract text from a text-based PDF via pdftotext.")
    pe.add_argument("pdf", help="PDF file.")
    pe.add_argument("--pages", help="Page range: N or N-M.")
    pe.add_argument("--no-layout", action="store_true", help="Disable -layout (raw text flow).")
    pe.set_defaults(func=cmd_extract)

    ph = sub.add_parser("html2pdf", help="Render an HTML doc to a print-optimized PDF.")
    ph.add_argument("html", help="Input .html file.")
    ph.add_argument("out", nargs="?", help="Output .pdf (default: alongside the input).")
    ph.set_defaults(func=cmd_html2pdf)

    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
